# =============================================================================
# GRIPTIX — MASTER ENVIRONMENT VARIABLES (FREE-TIER MIGRATED STACK)
# =============================================================================
# Copy this file to .env (local dev) or configure inside Doppler / Railway environment variables.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# =============================================================================


# =============================================================================
# SECTION 1 — APPLICATION
# =============================================================================
# Environment: development | staging | production
NODE_ENV=development
ENVIRONMENT=development

# Public base URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Internal API version prefix
API_V1_PREFIX=/api/v1


# =============================================================================
# SECTION 2 — DATABASE (Neon Serverless PostgreSQL)
# =============================================================================
# Source: Neon console → branch connection string
# SSL Mode required in production (?sslmode=require)
DATABASE_URL=postgresql://griptix_user:CHANGE_ME@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Individual connection components
DB_HOST=ep-xxx-xxx.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=griptix_user
DB_PASSWORD=CHANGE_ME

ALEMBIC_DATABASE_URL=postgresql://griptix_user:CHANGE_ME@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require


# =============================================================================
# SECTION 3 — AUTHENTICATION & JWT
# =============================================================================
# JWT_SECRET: generate with → openssl rand -hex 64
# NEXTAUTH_SECRET: generate with → openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# NextAuth.js configurations (apps/web)
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# OAuth integrations
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

APPLE_CLIENT_ID=CHANGE_ME
APPLE_CLIENT_SECRET=CHANGE_ME
APPLE_TEAM_ID=CHANGE_ME
APPLE_KEY_ID=CHANGE_ME
APPLE_PRIVATE_KEY=CHANGE_ME


# =============================================================================
# SECTION 4 — OBJECT STORAGE (Cloudflare R2 — S3-Compatible API)
# =============================================================================
# Source: Cloudflare Dashboard → R2 Object Storage
# Zero egress fee alternative to AWS S3
R2_ENDPOINT_URL=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME

# Buckets (griptix-uploads: private, griptix-media: public via CDN)
R2_UPLOADS_BUCKET=griptix-uploads
R2_MEDIA_BUCKET=griptix-media

# Public CDN domain mapped to the R2 media bucket
R2_MEDIA_PUBLIC_URL=https://media.griptix.in

# Presigned URL expiry for private uploads (seconds)
S3_PRESIGNED_URL_EXPIRE_SECONDS=900


# =============================================================================
# SECTION 5 — BACKEND DEPLOYMENT (Railway)
# =============================================================================
# Replaces AWS ECS/ECR and Fly.io
# Set these in Railway → Service → Variables dashboard (not in .env)
# Primary: Railway | Fallback: Render
RAILWAY_SERVICE_NAME=griptix-api
RAILWAY_ENVIRONMENT=production
RAILWAY_REGION=ap-south
GHCR_IMAGE=ghcr.io/your-org/griptix-api:latest
# Render fallback (if Railway quota exceeded)
# RENDER_SERVICE_ID=srv-CHANGE_ME
# RENDER_API_KEY=rnd_CHANGE_ME


# =============================================================================
# SECTION 6 — SECRETS INJECTION (Doppler Developer Plan)
# =============================================================================
# Replaces AWS Secrets Manager
DOPPLER_TOKEN=dp.pt.CHANGE_ME


# =============================================================================
# SECTION 7 — LOGGING & METRICS (Better Stack / Logtail)
# =============================================================================
# Replaces AWS CloudWatch Log Groups
LOGTAIL_SOURCE_TOKEN=CHANGE_ME


# =============================================================================
# SECTION 8 — CACHING (Upstash Redis Serverless)
# =============================================================================
# Replaces AWS ElastiCache
# Format: rediss://:password@host.upstash.io:6379
REDIS_URL=rediss://default:CHANGE_ME@griptix-redis.upstash.io:6379
REDIS_HOST=griptix-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME


# =============================================================================
# SECTION 9 — STRIPE
# =============================================================================
# Source: Stripe Dashboard → API keys
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_CURRENCY=usd


# =============================================================================
# SECTION 10 — RAZORPAY
# =============================================================================
# Source: Razorpay Dashboard → API Keys
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
RAZORPAY_CURRENCY=INR


# =============================================================================
# SECTION 11 — EMAIL SERVICE (Brevo / Sendinblue Transactional)
# =============================================================================
# Replaces SendGrid (300 free emails/day)
BREVO_API_KEY=xkeysib-CHANGE_ME
BREVO_FROM_EMAIL=orders@mail.griptix.in
BREVO_FROM_NAME=Griptix

# Brevo Template IDs (Integer values)
BREVO_TEMPLATE_ORDER_CONFIRMATION=1
BREVO_TEMPLATE_SIZING_VERIFIED=2
BREVO_TEMPLATE_SHIPPED=3
BREVO_TEMPLATE_REVIEW_REQUEST=4


# =============================================================================
# SECTION 12 — SMS SERVICE (Brevo SMS)
# =============================================================================
# Replaces Twilio
BREVO_SMS_API_KEY=xkeysib-CHANGE_ME
BREVO_SMS_FROM=Griptix
FEATURE_SMS_ENABLED=false


# =============================================================================
# SECTION 13 — WHATSAPP BUSINESS API (Meta)
# =============================================================================
WHATSAPP_API_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME
WHATSAPP_TEMPLATE_SHIPPED=order_shipped_international


# =============================================================================
# SECTION 14 — LLM REASONING (Groq Cloud API)
# =============================================================================
# Replaces Grok by xAI
GROQ_API_KEY=gsk_CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile


# =============================================================================
# SECTION 15 — SEARCH EMBEDDINGS (Hugging Face Inference API)
# =============================================================================
# Replaces Jina AI Embeddings API
HF_API_KEY=hf_CHANGE_ME
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5


# =============================================================================
# SECTION 16 — AI OBSERVABILITY (Langfuse Cloud)
# =============================================================================
# Replaces Opik SaaS (Cloud or self-hosted)
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PROJECT_NAME=griptix-agents


# =============================================================================
# SECTION 17 — ERROR TRACKING (Sentry Free Tier)
# =============================================================================
SENTRY_DSN_FRONTEND=https://CHANGE_ME@oXXXXXX.ingest.sentry.io/CHANGE_ME
SENTRY_DSN_BACKEND=https://CHANGE_ME@oXXXXXX.ingest.sentry.io/CHANGE_ME
NEXT_PUBLIC_SENTRY_DSN=https://CHANGE_ME@oXXXXXX.ingest.sentry.io/CHANGE_ME
SENTRY_ORG=CHANGE_ME
SENTRY_PROJECT_FRONTEND=griptix-web
SENTRY_PROJECT_BACKEND=griptix-api
SENTRY_AUTH_TOKEN=CHANGE_ME
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0


# =============================================================================
# SECTION 18 — VERCEL (Hobby Tier Deployments)
# =============================================================================
VERCEL_TOKEN=CHANGE_ME
VERCEL_ORG_ID=CHANGE_ME
VERCEL_PROJECT_ID=CHANGE_ME


# =============================================================================
# SECTION 19 — ANALYTICS & WEB PERFORMANCE
# =============================================================================
# GA4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-CHANGE_ME
# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=CHANGE_ME
# LinkedIn Insight Tag
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=CHANGE_ME
# Microsoft Clarity (Replaces Hotjar Site ID)
NEXT_PUBLIC_CLARITY_PROJECT_ID=CHANGE_ME


# =============================================================================
# SECTION 20 — CORS & SECURITY
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,https://griptix.in,https://www.griptix.in,https://staging.griptix.in
CSP_MODE=report-only


# =============================================================================
# SECTION 21 — RUNTIME FEATURE FLAGS
# =============================================================================
FEATURE_WHATSAPP_ENABLED=false
FEATURE_AI_SIZING_VALIDATION=false
FEATURE_SEMANTIC_SEARCH=false
FEATURE_PARTNER_PORTAL=false
FEATURE_BLOG_CMS=false


# =============================================================================
# SECTION 22 — SHIPPING ESTIMATOR (Domestic & International)
# =============================================================================
SHIPPING_DOMESTIC_FLAT_RATE_INR=350
SHIPPING_ZONE_1_RATE_INR=1200
SHIPPING_ZONE_2_RATE_INR=1800
SHIPPING_ZONE_3_RATE_INR=2500
SHIPPING_DOMESTIC_CARRIER=BlueDart
SHIPPING_INTERNATIONAL_CARRIER=FedEx


# =============================================================================
# SECTION 23 — GOOGLE SEARCH CONSOLE & SEO
# =============================================================================
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://griptix.in
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/gsc-service-account.json
